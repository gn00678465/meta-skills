# .npmrc for npm — supply-chain hardening
#
# Place at repo root and commit it (but read the AUTH WARNING below).
# Merge these keys into an existing .npmrc — do not replace.
#
# ⚠️ AUTH WARNING: Never commit `_authToken`, `_auth`, `_password`, or
# `email` lines in a repo .npmrc. Auth lives in ~/.npmrc (per-user) or comes
# from a CI env var via interpolation:
#   //registry.npmjs.org/:_authToken=${NPM_TOKEN}
# (The ${NPM_TOKEN} form is safe to commit — the literal token is not.)
#
# Audit before commit:
#   grep -E '_authToken=npm_|_auth=|_password|email=' .npmrc          (bash)
#   Select-String -Path .npmrc -Pattern '_authToken=npm_|_auth=|_password|email='  (pwsh)
#
# If a token is already in git history, ROTATE THE TOKEN FIRST, then rewrite
# history (git filter-repo --replace-text) and force-push. Assume the token
# is leaked even after rewrite — anyone who cloned before still has it.
#
# Rationale and verification: ../../references/package-managers/npm.md
# Upstream docs: https://docs.npmjs.com/cli/v11/using-npm/config

# Minimum release age — refuse versions younger than this.
# Requires npm >= 11.10. Unit: DAYS (not minutes, not seconds).
# 7 = 7 days. Lower bound: 3 days. Do not weaken without a written reason.
min-release-age=7

# Strip ^/~ on new installs.
# ⚠️ Existing ranges in package.json keep floating until the lockfile is
# regenerated. To pin the existing tree after switching the policy:
#   npm install --package-lock-only
save-exact=true

# ⚠️ KILL-SWITCH for lifecycle scripts. Disabling scripts breaks native-build
# packages: esbuild, sharp, prisma, puppeteer, playwright, cypress, swc,
# node-sass, bcrypt, canvas, better-sqlite3, node-gyp.
#
# DO NOT uncomment until you have an allowlist in place via
# @lavamoat/allow-scripts:
#   npx allow-scripts setup       # one-time
#   npx allow-scripts auto        # interactively populate the allowlist
#
# Then in CI:
#   npm ci --ignore-scripts       # install without scripts
#   npx allow-scripts run         # run only allowlisted scripts
#
# Once the allowlist is in package.json, uncomment the line below.
# See ../../references/lifecycle-script-allowlists.md
# ignore-scripts=true
