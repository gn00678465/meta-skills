        "files_required": ["prd.json", ".ralph/ralph.js", ".ralph/prompt.md", ".ralph/RUNBOOK.md", ".ralph/progress.txt", ".gitignore", ".ralph/package.json"],
        "prd_constraints": {
          "runner_command_contains": "copilot",
          "min_user_stories": 3,
          "max_user_stories": 12,
          "runtime": "js"
        },
        "driver_eval_required": true,
        "amend_mode": false
      }
    },
