        "prd_constraints": {
          "runner_command_contains": "claude",
          "min_user_stories": 3,
          "max_user_stories": 12,
          "runtime": "sh"
        },
        "driver_eval_required": true,
        "amend_mode": false
      }
    },
    {
      "id": "boot-js-copilot-zh",
